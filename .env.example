# Copy this to .env.local and fill in your values

# Firebase (shared project — get config from Firebase Console)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Your Anthropic Claude API key — get one at https://console.anthropic.com
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...

# Unpaywall API email (required by their API, just use any email)
EXPO_PUBLIC_UNPAYWALL_EMAIL=medlit@example.com
